# 知径（Zhijing）环境变量配置示例
# 复制为 .env 并填写实际值，或在部署平台的环境变量中配置
# author: fxbin

# ===== 服务运行 =====
# 监听端口（部署平台通常自动注入 PORT）
PORT=8787
# 生产模式设为 production，启用前端静态文件服务
NODE_ENV=production
# 日志级别
LOG_LEVEL=info

# ===== 安全门禁（公网部署必填）=====
# 访问密码，未设置则门禁不启用（本地开发场景）
# 公网部署必须设置，建议 16 位以上随机字符串
ZHIJING_ACCESS_PASSWORD=changeme-to-strong-password
# 访问令牌签名密钥，建议与密码不同
# 未设置时由密码派生，重启后已签发令牌仍有效
ZHIJING_ACCESS_TOKEN_SECRET=another-random-secret-string

# ===== LLM Provider 配置 =====
# 主路径：部署后通过 Settings 页面创建并激活 Profile（推荐，存 SQLite 持久化）
#   1. 访问域名 → 输入密码 → 进入主界面
#   2. Settings → 模型配置 → 创建 Profile
#      - 服务商：deepseek / openai / qwen / doubao 等
#      - 模型：deepseek-chat / gpt-4o-mini 等
#      - API Key：粘贴你的 Key
#      - Base URL：留空使用 SDK 默认端点（或填自定义端点）
#   3. 保存 → 激活 → 测试连接
# 兜底：如果 Profile 未激活，以下环境变量作为回退（仅对已知 provider 生效）
# 注意：自定义 provider 必须走 Settings 页面配置，环境变量兜底不支持
# ZHIJING_PI_ENABLED=1
# ZHIJING_PI_PROVIDER=deepseek
# ZHIJING_PI_MODEL=deepseek-chat
# ZHIJING_PI_API_KEY=sk-your-key
# ZHIJING_PI_BASE_URL=
# ZHIJING_PI_FALLBACK=0

# ===== CORS 允许来源 =====
# 多个用逗号分隔，禁用通配符 *
# 部署后填实际域名或 IP，如 https://zhijing.example.com
ZHIJING_ALLOWED_ORIGINS=https://zhijing.example.com

# ===== 调试路由（可选，建议关闭）=====
# inspect 调试路由访问令牌，未设置则 inspect 路由返回 404
# ZHIJING_INSPECT_TOKEN=

# ===== 联网搜索（推荐配置）=====
# Jina Reader API Key（联网搜索主 provider，注册地址 https://jina.ai/reader）
JINA_API_KEY=
# Tavily API Key（Jina 失效时的兜底搜索 provider，免费 1000 次/月，注册地址 https://app.tavily.com）
TAVILY_API_KEY=

# ===== 解析相关（可选）=====
# 小红书 Cookie（如需解析小红书笔记）
# XHS_COOKIE=
# 抖音/通用代理（如需代理）
# DOUYIN_PROXY=
