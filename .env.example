# 知径（Zhijing）环境变量配置示例
# 复制为 .env 并填写实际值，或在部署平台的环境变量中配置
# author: fxbin

# ===== 服务运行 =====
# 监听端口（部署平台通常自动注入 PORT）
PORT=8787
# 生产模式设为 production，启用前端静态文件服务
NODE_ENV=production
# 日志级别
LOG_LEVEL=info

# ===== 安全门禁（公网部署必填）=====
# 访问密码，未设置则门禁不启用（本地开发场景）
# 公网部署必须设置，建议 16 位以上随机字符串
ZHIJING_ACCESS_PASSWORD=changeme-to-strong-password
# 访问令牌签名密钥，建议与密码不同
# 未设置时由密码派生，重启后已签发令牌仍有效
ZHIJING_ACCESS_TOKEN_SECRET=another-random-secret-string

# ===== LLM Provider 配置（公网部署必填）=====
# Provider 名称：openai / deepseek / qwen / doubao / anthropic 等
ZHIJING_PI_PROVIDER=openai
# 模型 ID
ZHIJING_PI_MODEL=gpt-4o-mini
# API Key（建议使用低额度演示 Key）
ZHIJING_PI_API_KEY=sk-your-low-quota-demo-key
# 启用 LLM（1 启用）
ZHIJING_PI_ENABLED=1
# 启用 mock 回退（0 禁用，LLM 不可用时返回 mock 响应）
ZHIJING_PI_FALLBACK=0

# ===== CORS 允许来源 =====
# 多个用逗号分隔，禁用通配符 *
# Zeabur 部署后填实际域名，如 https://zhijing.zeabur.app
ZHIJING_ALLOWED_ORIGINS=https://zhijing.zeabur.app

# ===== 调试路由（可选，建议关闭）=====
# inspect 调试路由访问令牌，未设置则 inspect 路由返回 404
# ZHIJING_INSPECT_TOKEN=

# ===== 解析相关（可选）=====
# 小红书 Cookie（如需解析小红书笔记）
# XHS_COOKIE=
# Jina Reader API Key（如需网页解析增强）
# JINA_API_KEY=
# 抖音/通用代理（如需代理）
# DOUYIN_PROXY=
