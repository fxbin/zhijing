# 知径（Zhijing）环境变量配置示例
# 复制为 .env 并填写实际值，或在部署平台的环境变量中配置
# author: fxbin

# ===== 安全门禁（公网部署必填）=====
# 访问密码，建议 16 位以上随机字符串，未设置则门禁不启用
ZHIJING_ACCESS_PASSWORD=
# 访问令牌签名密钥，建议与密码不同，未设置时由密码派生
ZHIJING_ACCESS_TOKEN_SECRET=

# ===== CORS 允许来源（公网部署必填）=====
# 多个用逗号分隔，禁用通配符 *，填实际域名或 IP
ZHIJING_ALLOWED_ORIGINS=

# ===== LLM Provider =====
# 部署后通过 Settings 页面创建并激活 Profile 配置，无需环境变量

# ===== 联网搜索（推荐配置）=====
# Jina API Key（主搜索 provider，注册地址 https://jina.ai/reader）
JINA_API_KEY=
# Tavily API Key（兜底搜索 provider，免费 1000 次/月，注册地址 https://app.tavily.com）
TAVILY_API_KEY=

# ===== 可选 =====
# XHS_COOKIE=              # 小红书笔记解析
# DOUYIN_PROXY=            # 抖音视频代理
# DOUYIN_COOKIE_TTL=21600  # 抖音访客 cookie 缓存有效期（秒），默认 6 小时
# ZHIJING_INSPECT_TOKEN=   # 调试路由令牌，未设置则 inspect 路由返回 404
